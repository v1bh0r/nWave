/**
 * nWave DES Plugin for OpenCode
 *
 * Translates OpenCode hook events to Claude Code JSON format and invokes
 * the Python DES adapter via subprocess. All enforcement logic lives in
 * the Python DES engine -- this shim is a protocol translator only.
 *
 * Generated by nwave-ai install. Do not edit manually.
 *
 * Template placeholders (replaced at install time):
 *   {{PYTHON_PATH}}  -- absolute path to python3
 *   {{PYTHONPATH}}    -- path to DES lib (e.g., ~/.claude/lib/python)
 */

import type { Plugin } from "@opencode-ai/plugin";

// Translation table: OpenCode tool name -> Claude Code format
const TOOL_MAP: Record<string, { action: string; toolName: string }> = {
  task:  { action: "pre-task",  toolName: "Agent" },
  write: { action: "pre-write", toolName: "Write" },
  edit:  { action: "pre-write", toolName: "Edit"  },
};

// Translate an OpenCode event to Claude Code JSON format
function translateEvent(
  tool: string,
  input: Record<string, unknown>,
): { action: string; ccJson: Record<string, unknown> } | null {
  const mapping = TOOL_MAP[tool];
  if (!mapping) return null;

  const toolInput: Record<string, unknown> = {};

  if (tool === "task") {
    toolInput.prompt = input.prompt ?? "";
    toolInput.subagent_type = input.agent ?? "";
  } else {
    // write and edit: pass through all input fields
    Object.assign(toolInput, input);
  }

  return {
    action: mapping.action,
    ccJson: {
      tool_name: mapping.toolName,
      tool_input: toolInput,
    },
  };
}

// Invoke the Python DES adapter via subprocess
async function invokeDESAdapter(
  action: string,
  ccJson: Record<string, unknown>,
): Promise<{ exitCode: number; stdout: string; stderr: string }> {
  const proc = Bun.spawn(
    ["{{PYTHON_PATH}}", "-m", "des.adapters.drivers.hooks.claude_code_hook_adapter", action],
    {
      stdin: new Blob([JSON.stringify(ccJson)]),
      stdout: "pipe",
      stderr: "pipe",
      env: { ...process.env, PYTHONPATH: "{{PYTHONPATH}}" },
    },
  );

  const timeout = setTimeout(() => {
    try { proc.kill(); } catch {}
    console.error("[nWave DES] Python adapter exceeded 5s timeout");
  }, 5000);

  const exitCode = await proc.exited;
  clearTimeout(timeout);

  const stdout = await new Response(proc.stdout).text();
  const stderr = await new Response(proc.stderr).text();

  return { exitCode, stdout, stderr };
}

// Module-level flag: degraded mode warning emitted once per session
let _degradedModeWarned = false;

function emitDegradedModeWarning(): void {
  if (_degradedModeWarned) return;
  _degradedModeWarned = true;
  console.error(
    "\u26a0 nWave DES: Running in degraded mode on OpenCode. " +
    "Sub-agent tool calls are not enforced (OpenCode Issue #5894)."
  );
}

export default function nwaveDES(_ctx: Plugin) {
  return {
    "session.created": async (_event: Record<string, unknown>) => {
      // Emit degraded mode warning once per session
      emitDegradedModeWarning();

      // Invoke Python adapter for session housekeeping
      try {
        await invokeDESAdapter("session-start", {});
      } catch (err) {
        // Fail-open: session start must never block
        console.error(`[nWave DES] Session start error (fail-open): ${err}`);
      }
    },

    "tool.execute.before": async (input: { tool: string; args: Record<string, unknown> }, output: Record<string, unknown>) => {
      // Filter: skip tools not relevant to DES
      const translated = translateEvent(input.tool, output.args ?? {});
      if (!translated) return;

      try {
        const result = await invokeDESAdapter(translated.action, translated.ccJson);

        if (result.stderr) {
          console.error(`[nWave DES] ${result.stderr.trim()}`);
        }

        // Exit 0 = allow, Exit 2 = block, anything else = fail-open
        if (result.exitCode === 2) {
          let reason = "DES enforcement blocked this action";
          try {
            const parsed = JSON.parse(result.stdout);
            if (parsed.reason) reason = parsed.reason;
          } catch {}
          throw new Error(reason);
        }
        // Exit 0 or any other code: allow (fail-open)
      } catch (err) {
        // Re-throw DES block errors (exit code 2)
        if (err instanceof Error && err.message.startsWith("DES")) {
          throw err;
        }
        // All other errors: fail-open (allow the tool call)
        console.error(`[nWave DES] Subprocess error (fail-open): ${err}`);
      }
    },
  };
}
